def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--self-test", action="store_true")
    parser.add_argument("--input")
    parser.add_argument("--output")
    parser.add_argument("--reference")
    parser.add_argument("--structure-manifest")
    parser.add_argument("--failures")
    args = parser.parse_args()

    if args.self_test:
        _self_test()
        return

    if not args.output or not args.structure_manifest:
        raise SystemExit("--output and --structure-manifest are required unless --self-test is used.")

    manifest_rows = _read_structure_manifest(Path(args.structure_manifest))
    output_rows = []
    failure_rows = []
    total_rows = len(manifest_rows)
    print(f"TMDET starting on {total_rows} structure(s).", file=sys.stderr, flush=True)
    with tempfile.TemporaryDirectory() as tmp_dir:
        work_dir = Path(tmp_dir)
        env_file = work_dir / "tmdet.env"
        env_file.write_text("", encoding="utf-8")
        for index, row in enumerate(manifest_rows, start=1):
            pdb_code = row["pdb_code"]
            structure_path = work_dir / f"{pdb_code}.cif.gz"
            transformed_path = work_dir / f"{pdb_code}.transformed.cif.gz"
            xml_path = work_dir / f"{pdb_code}.xml"
            if index == 1 or index % 25 == 0 or index == total_rows:
                print(
                    f"TMDET progress {index}/{total_rows}: {pdb_code}",
                    file=sys.stderr,
                    flush=True,
                )
            try:
                _download_structure(row["structure_url"], structure_path)
                completed = subprocess.run(
                    [
                        "tmdet",
                        "-pi",
                        str(structure_path),
                        "-po",
                        str(transformed_path),
                        "-x",
                        str(xml_path),
                        "-e",
                        str(env_file),
                    ],
                    shell=False,
                    capture_output=True,
                    text=True,
                    timeout=300,
                    env={**os.environ, "LD_LIBRARY_PATH": f"/usr/local/lib:{os.environ.get('LD_LIBRARY_PATH', '')}".rstrip(":")},
                )
                if completed.returncode != 0 or not xml_path.exists():
                    raise RuntimeError(str(completed.stderr or completed.stdout or "missing XML output").strip())
                regions = _parse_tmdet_xml(xml_path)
                output_rows.append(
                    {
                        "pdb_code": pdb_code,
                        "tm_count": len(regions),
                        "tm_regions": json.dumps(regions),
                    }
                )
            except Exception as exc:
                print(
                    f"TMDET failure {pdb_code}: {str(exc).strip() or 'TMDET execution failed'}",
                    file=sys.stderr,
                    flush=True,
                )
                failure_rows.append(
                    {
                        "pdb_code": pdb_code,
                        "error_message": str(exc).strip() or "TMDET execution failed",
                    }
                )

    output_path = Path(args.output)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    with output_path.open("w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=["pdb_code", "tm_count", "tm_regions"])
        writer.writeheader()
        for row in output_rows:
            writer.writerow(row)

    failures_path = Path(args.failures) if args.failures else output_path.with_name("failures.csv")
    failures_path.parent.mkdir(parents=True, exist_ok=True)
    with failures_path.open("w", newline="") as handle:
        writer = csv.DictWriter(handle, fieldnames=["pdb_code", "error_message"])
        writer.writeheader()
        for row in failure_rows:
            writer.writerow(row)

    if failure_rows:
        print(
            f"TMDET completed with {len(output_rows)} success(es) and {len(failure_rows)} failure(s).",
            file=sys.stderr,
        )


if __name__ == "__main__":
    main()
